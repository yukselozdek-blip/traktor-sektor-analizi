# Database
DATABASE_URL=postgresql://traktor:traktor2024secure@localhost:5432/traktorsektordb
POSTGRES_USER=traktor
POSTGRES_PASSWORD=traktor2024secure
POSTGRES_DB=traktorsektordb

# Application
NODE_ENV=development
PORT=3000
JWT_SECRET=traktor-sektor-super-secret-key-2024
APP_BASE_URL=https://your-railway-app.up.railway.app
WHATSAPP_QUERY_API_KEY=change-this-internal-query-token
N8N_WHATSAPP_PROCESSOR_URL=https://your-n8n-service.up.railway.app/webhook/whatsapp-sales-assistant-process-v4
N8N_MODEL_INTEL_WEBHOOK_URL=https://your-n8n-service.up.railway.app/webhook/model-intelligence
MEDIA_WATCH_WEBHOOK_KEY=change-this-media-watch-key
MEDIA_WATCH_N8N_WEBHOOK_URL=http://127.0.0.1:5680/webhook/media-watch-pack-1
MEDIA_WATCH_N8N_WEBHOOK_URL_PACK_2=http://127.0.0.1:5680/webhook/media-watch-pack-2
MEDIA_WATCH_N8N_WEBHOOK_URL_PACK_3=http://127.0.0.1:5680/webhook/media-watch-pack-3
MEDIA_WATCH_BRIDGE_PORT=3011
MEDIA_WATCH_BRIDGE_HOST=127.0.0.1
MEDIA_WATCH_BRIDGE_AUTORUN=true
MEDIA_WATCH_BRIDGE_SCHEDULE=*/30 * * * *
MEDIA_WATCH_BRIDGE_PACKS=pack-1,pack-2,pack-3
# DIRECT MODE: n8n'i bypass et, doğrudan app'in /api/media-watch/ingest'ine POST at (varsayılan: true)
MEDIA_WATCH_BRIDGE_DIRECT=true
# Bridge'in app'e ulaşacağı base URL (lokal: http://127.0.0.1:3002, Docker: http://app:3000, Railway: https://your-app.up.railway.app)
MEDIA_WATCH_APP_BASE_URL=http://127.0.0.1:3002
# Server.js bridge'i child_process olarak otomatik başlatsın (lokal kolaylık)
MEDIA_WATCH_BRIDGE_AUTOSTART=true

# Model Image Bridge (Marka Merkezi görsel doğrulama servisi)
MODEL_IMAGE_BRIDGE_URL=http://127.0.0.1:3012
MODEL_IMAGE_BRIDGE_PORT=3012
MODEL_IMAGE_BRIDGE_HOST=127.0.0.1
MODEL_IMAGE_BRIDGE_AUTORUN=false
MODEL_IMAGE_BRIDGE_SCHEDULE=0 */6 * * *
MODEL_IMAGE_BRIDGE_BATCH=12
MODEL_IMAGE_BRIDGE_TIMEOUT_MS=15000
MODEL_IMAGE_BRIDGE_DELAY_MS=1200
N8N_MODEL_IMAGE_WEBHOOK_URL=http://127.0.0.1:5680/webhook/model-image-crawler

# Search & Vision (görsel arama + AI doğrulama)
BING_SEARCH_API_KEY=your-bing-search-api-key
BRAVE_SEARCH_API_KEY=your-brave-search-api-key
GROQ_API_KEY=your-groq-api-key
