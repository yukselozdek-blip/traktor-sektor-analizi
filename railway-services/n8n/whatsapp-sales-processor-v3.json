{
  "id": "whatsapp-sales-processor-v3",
  "name": "WhatsApp Sales Processor v3",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "whatsapp-sales-assistant-process-v3",
        "options": {}
      },
      "name": "WhatsApp Processor Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2.1,
      "webhookId": "15a34ca1-9cf8-4e12-b2d1-b66980509ec7",
      "position": [
        240,
        260
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "leftValue": "={{$json.headers[\"x-query-token\"] || \"\"}}",
              "rightValue": "={{$env.WHATSAPP_QUERY_API_KEY}}",
              "operator": {
                "type": "string",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        }
      },
      "name": "Forward Token Match",
      "type": "n8n-nodes-base.if",
      "position": [
        480,
        260
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ (($env.APP_BASE_URL || 'http://app:3000').replace(/\\/$/, '')) + '/api/public/assistant/sales-query' }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "x-query-token",
              "value": "={{$env.WHATSAPP_QUERY_API_KEY}}"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ ({ question: $json.body?.question || $json.question, from: $json.body?.from || $json.from, message_id: $json.body?.message_id || $json.message_id }) }}"
      },
      "name": "Resolve Sales Answer",
      "type": "n8n-nodes-base.httpRequest",
      "position": [
        760,
        180
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://graph.facebook.com/v21.0/{{$env.WHATSAPP_PHONE_NUMBER_ID}}/messages",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{$env.WHATSAPP_ACCESS_TOKEN}}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ ({ messaging_product: 'whatsapp', to: $json.body?.from || $('WhatsApp Processor Webhook').item.json.body?.from || $('WhatsApp Processor Webhook').item.json.from, type: 'text', text: { body: $json.answer || 'Sorunuz islenemedi.' } }) }}"
      },
      "name": "Send WhatsApp Reply",
      "type": "n8n-nodes-base.httpRequest",
      "position": [
        1040,
        180
      ]
    }
  ],
  "connections": {
    "WhatsApp Processor Webhook": {
      "main": [
        [
          {
            "node": "Forward Token Match",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Forward Token Match": {
      "main": [
        [
          {
            "node": "Resolve Sales Answer",
            "type": "main",
            "index": 0
          }
        ],
        []
      ]
    },
    "Resolve Sales Answer": {
      "main": [
        [
          {
            "node": "Send WhatsApp Reply",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  }
}
